<div class="container mt-4" style="max-width:500px;">
    <h3>코드 <%= mode === 'create' ? '입력' : '수정' %></h3>
    <form action="/code/<%= mode === 'create' ? 'create_process' : 'update_process' %>" method="POST">
        <% if (mode === 'update') { %>
            <input type="hidden" name="main_id" value="<%= data.main_id %>">
            <input type="hidden" name="sub_id" value="<%= data.sub_id %>">
            <input type="hidden" name="start" value="<%= data.start %>">
            <input type="hidden" name="end" value="<%= data.end %>">
        <% } %>

        <% if (mode === 'create') { %>
        <div class="mb-3">
            <label class="form-label">대분류</label>
            <input type="text" name="main_id" class="form-control" value="<%= data.main_id %>" required>
        </div>
        <% } %>
        <div class="mb-3">
            <label class="form-label">대분류명</label>
            <input type="text" name="main_name" class="form-control" value="<%= data.main_name %>" required>
        </div>
        <% if (mode === 'create') { %>
        <div class="mb-3">
            <label class="form-label">소분류</label>
            <input type="text" name="sub_id" class="form-control" value="<%= data.sub_id %>" required>
        </div>
        <% } %>
        <div class="mb-3">
            <label class="form-label">소분류명</label>
            <input type="text" name="sub_name" class="form-control" value="<%= data.sub_name %>" required>
        </div>
        <% if (mode === 'create') { %>
        <div class="mb-3">
            <label class="form-label">시작일</label>
            <input type="text" name="start" class="form-control" value="<%= data.start %>" required>
        </div>
        <% } %>
        <div class="mb-3">
            <label class="form-label">종료일</label>
            <input type="text" name="end" class="form-control" value="<%= data.end %>" required>
        </div>
        <button type="submit" class="btn btn-primary"><%= mode === 'create' ? '입력' : '수정' %></button>
        <a href="/code/view" class="btn btn-secondary">코드 목록 돌아가기</a>
    </form>
</div>
