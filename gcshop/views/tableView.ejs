<div class="container mt-4">
    <h3><%= tableName %> 자료 목록</h3>

    <table class="table table-bordered border-primary table-hover mt-3" style="text-align: center; font-size: 13px;">
        <thead class="table-primary">
            <tr>
                <% for (var c = 0; c < columns.length; c++) { %>
                    <% if (columns[c].COLUMN_KEY !== 'PRI') { %>
                        <th><%= columns[c].COLUMN_COMMENT || columns[c].COLUMN_NAME %></th>
                    <% } %>
                <% } %>
                <th colspan="3"></th>
            </tr>
        </thead>
        <tbody>
            <% if (data.length === 0) { %>
                <tr><td colspan="<%= columns.length + 2 %>">데이터가 없습니다.</td></tr>
            <% } else { %>
                <% for (var i = 0; i < data.length; i++) { %>
                <tr>
                    <% for (var c = 0; c < columns.length; c++) { %>
                        <% if (columns[c].COLUMN_KEY !== 'PRI') { %>
                            <td><%= data[i][columns[c].COLUMN_NAME] != null ? data[i][columns[c].COLUMN_NAME] : '' %></td>
                        <% } %>
                    <% } %>
                    <td><a href="/table/create/<%= tableName %>">생성</a></td>
                    <td><a href="/table/update/<%= tableName %>/<%= data[i][pkColumn] %>">수정</a></td>
                    <td><a href="/table/delete/<%= tableName %>/<%= data[i][pkColumn] %>" onclick="if(confirm('정말로 삭제하시겠습니까?')==false) return false">삭제</a></td>
                </tr>
                <% } %>
            <% } %>
        </tbody>
    </table>

    <a href="/table/create/<%= tableName %>">
        <button class="btn btn-outline-secondary btn-sm">데이터 추가</button>
    </a>
    <a href="/table">
        <button class="btn btn-outline-secondary btn-sm">테이블 목록</button>
    </a>
</div>
