<div class="container mt-4" style="max-width:500px;">
    <% if (typeof mode !== 'undefined' && mode === 'register') { %>
        <h3>회원가입</h3>
    <% } else { %>
        <h3><%= mode === 'create' ? '관리자 기능 : 회원생성' : '관리자 기능 : 회원 정보 수정' %></h3>
    <% } %>

    <% var actionUrl = '';
       if (typeof mode !== 'undefined' && mode === 'register') {
           actionUrl = '/auth/register_process';
       } else if (mode === 'create') {
           actionUrl = '/person/create_process';
       } else {
           actionUrl = '/person/update_process';
       }
    %>

    <form action="<%= actionUrl %>" method="POST">
        <% if (mode === 'update') { %>
            <input type="hidden" name="loginid" value="<%= data.loginid %>">
        <% } %>

        <% if (mode !== 'update') { %>
        <div class="mb-3">
            <label class="form-label">ID</label>
            <input type="text" name="loginid" class="form-control"
                   value="<%= data.loginid %>" placeholder="아이디를 입력해 주세요" required>
        </div>
        <% } %>
        <div class="mb-3">
            <label class="form-label">PW</label>
            <input type="password" name="password" class="form-control"
                   value="<%= data.password %>" placeholder="패스워드를 입력해 주세요" required>
        </div>
        <div class="mb-3">
            <label class="form-label">이름</label>
            <input type="text" name="name" class="form-control"
                   value="<%= data.name %>" placeholder="이름을 입력해 주세요" required>
        </div>
        <div class="mb-3">
            <label class="form-label">성별</label>
            <div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="mf" value="M"
                           <%= data.mf === 'M' ? 'checked' : '' %>>
                    <label class="form-check-label">남자</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="radio" name="mf" value="F"
                           <%= data.mf === 'F' ? 'checked' : '' %>>
                    <label class="form-check-label">여자</label>
                </div>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">주소</label>
            <input type="text" name="address" class="form-control"
                   value="<%= data.address %>" placeholder="주소를 입력해 주세요">
        </div>
        <div class="mb-3">
            <label class="form-label">전화번호</label>
            <input type="text" name="tel" class="form-control"
                   value="<%= data.tel %>" placeholder="000-0000-0000">
        </div>
        <div class="mb-3">
            <label class="form-label">생일</label>
            <input type="text" name="birth" class="form-control"
                   value="<%= data.birth %>" placeholder="YYYYMMDD" required>
        </div>

        <% if (typeof mode !== 'undefined' && mode !== 'register') { %>
        <div class="mb-3">
            <label class="form-label">CLASS</label>
            <select name="cls" class="form-select">
                <option value="CST" <%= data.class === 'CST' ? 'selected' : '' %>>고객</option>
                <option value="MNG" <%= data.class === 'MNG' ? 'selected' : '' %>>관리자</option>
                <option value="CEO" <%= data.class === 'CEO' ? 'selected' : '' %>>경영자</option>
            </select>
        </div>
        <% } %>

        <button type="submit" class="btn btn-primary">
            <%= (mode === 'create' || mode === 'register') ? '입력' : '수정' %>
        </button>

        <% if (mode === 'register') { %>
            <a href="/" class="btn btn-secondary">돌아가기</a>
        <% } else { %>
            <a href="/person/view" class="btn btn-secondary">고객 목록 돌아가기</a>
        <% } %>
    </form>
</div>
