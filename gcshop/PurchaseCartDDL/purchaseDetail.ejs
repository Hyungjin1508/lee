<div class="container mt-4">
    <table class="table table-bordered">
        <form method="post">
            <input type="hidden" name="prod_id" value="<%= data.prod_id %>">
            <tr>
                <td rowspan="5">
                    ![image](/images/<%= data.image %>)
                </td>
                <td><strong><%= data.name %></strong></td>
            </tr>
            <tr><td>가격 : <%= data.price ? data.price.toLocaleString() : 0 %> 원</td></tr>
            <tr><td>브랜드 : <%= data.brand %></td></tr>
            <tr><td>수량 : <input type="number" name="qty" value="1" min="1"></td></tr>
            <tr>
                <td>
                    <button class="btn btn-outline-primary btn-sm" formaction="/purchase/purchase_process" type="submit">결재</button>
                    <button class="btn btn-outline-primary btn-sm" formaction="/purchase/addcart" type="submit">장바구니</button>
                </td>
            </tr>
        </form>
    </table>
</div>
