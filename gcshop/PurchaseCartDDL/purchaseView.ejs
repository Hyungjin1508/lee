<div class="container mt-4">
    <h3>구매 관리 (관리자)</h3>
    <table class="table table-bordered mt-3" style="text-align: center; font-size: 13px;">
        <tr style="vertical-align: middle;">
            <th>고객ID</th><th>고객명</th>
            <th>상품ID</th><th>상품명</th>
            <th>구매일</th><th>가격</th>
            <th>포인트</th><th>구매량</th>
            <th>총가격</th><th>지불여부</th>
            <th>취소여부</th><th>환불여부</th>
            <th colspan="2"></th>
        </tr>

        <% if (typeof data !== 'undefined' && data.length > 0) { %>
            <% for (var i = 0; i < data.length; i++) { %>
            <tr style="vertical-align: middle;">
                <td><%= data[i].loginid %></td>
                <td><%= data[i].cust_name %></td>
                <td><%= data[i].prod_id %></td>
                <td><%= data[i].prod_name %></td>
                <td><%= data[i].date %></td>
                <td><%= data[i].price ? data[i].price.toLocaleString() : 0 %> 원</td>
                <td><%= data[i].point %></td>
                <td><%= data[i].qty %></td>
                <td><%= data[i].total ? data[i].total.toLocaleString() : 0 %>원</td>
                <td><%= data[i].payYN %></td>
                <td><%= data[i].cancel %></td>
                <td>N</td>
                <td><a href="/purchase/purchaseupdate/<%= data[i].purchase_id %>" style="text-decoration: none;">수정</a></td>
                <td><a href="/purchase/purchasedelete/<%= data[i].purchase_id %>" style="text-decoration: none;" onclick="if(confirm('정말로 삭제하시겠습니까?')==false) return false">삭제</a></td>
            </tr>
            <% } %>
        <% } else { %>
            <tr><td colspan="14">구매 내역이 없습니다.</td></tr>
        <% } %>
    </table>
</div>
