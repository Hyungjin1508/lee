<div class="container mt-4">
    <h3>장바구니</h3>
    <script>
        function actionCheck(event) {
            var tempOfCheck = 0;
            $("input[name=check]:checked").each(function(){
                tempOfCheck += 1;
            });
            var numOfCheck = document.getElementById('total');
            numOfCheck.value = tempOfCheck;
        }
    </script>

    <table class="table table-bordered mt-3">
        <form action="/purchase/cartpurchase_process" method="post">
            <tr>
                <th>구매선택</th>
                <th>상품</th>
                <th>상품명</th>
                <th>단가</th>
                <th>담은날</th>
                <th>수량</th>
            </tr>

            <% if (typeof data !== 'undefined' && data.length > 0) { %>
                <% for (var i = 0; i < data.length; i++) { %>
                <tr style="text-align: center; vertical-align: middle;">
                    <td>
                        <input type="checkbox" name="check" value="<%= data[i].cart_id %>" onClick="actionCheck(event)">
                    </td>
                    <td>
                        <a href="/detail/<%= data[i].prod_id %>" style="text-decoration: none;">
                            ![image](/images/<%= data[i].image %>)
                        </a>
                    </td>
                    <td><%= data[i].prod_name %></td>
                    <td><%= data[i].price ? data[i].price.toLocaleString() : 0 %> 원</td>
                    <td><%= data[i].date %></td>
                    <td><input type="number" name="qty" value="1" min="1"></td>
                </tr>
                <% } %>
            <% } else { %>
                <tr><td colspan="6" style="text-align:center;">장바구니가 비어있습니다.</td></tr>
            <% } %>
    </table>

    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
        <button class="btn btn-outline-primary btn-sm" type="submit">결재</button>
        <input type="hidden" id="total" name="numOfCheck" value="0">
        <button class="btn btn-outline-primary btn-sm"
            onclick="if(confirm('정말로 삭제하시겠습니까?')==false){ return false} else { form.action = '/purchase/cartdelete_process'; }">삭제</button>
        </form>
        <a href="/"><button class="btn btn-outline-primary btn-sm">상품 목록 돌아가기</button></a>
    </div>
</div>
