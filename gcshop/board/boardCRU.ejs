<div class="container mt-4">

<% if (mode === 'create') { %>
    <!-- ==================== 글쓰기 모드 ==================== -->
    <h2><%= boardtype.title %> 작성</h2>
    <form action="/board/create_process" method="post">
        <input type="hidden" name="type_id" value="<%= data.type_id %>">
        <input type="hidden" name="loginid" value="<%= loginid %>">
        <div class="mb-3">
            <label class="form-label">제목</label>
            <input class="form-control" type="text" name="title" style="width:300px;">
        </div>
        <div class="mb-3">
            <label class="form-label">작성자</label>
            <input class="form-control" type="text" value="<%= who %>" style="width:300px;" disabled>
        </div>
        <div class="mb-3">
            <label class="form-label">내용</label>
            <textarea class="form-control" name="content" style="width:800px; height:200px;"></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">갱신삭제시 비밀번호</label>
            <input class="form-control" type="text" name="password" style="width:300px;">
        </div>
        <button class="btn btn-outline-primary btn-sm" type="submit">생성</button>
        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/board/view/<%= boardtype.numPerPage %>/<%= data.type_id %>">
                <button type="button" class="btn btn-info me-md-2">목록</button>
            </a>
        </div>
    </form>

<% } else if (mode === 'read') { %>
    <!-- ==================== 글 상세보기 모드 ==================== -->
    <table class="table table-bordered mt-3">
        <tr><th style="width:100px;">제목</th><td><%= data.title %></td></tr>
        <tr><th>작성자</th><td><%= data.writer_name || data.loginid %></td></tr>
        <tr><th>작성일</th><td><%= data.date %></td></tr>
        <tr><th>내용</th><td style="white-space: pre-wrap;"><%= data.content %></td></tr>
    </table>

    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
        <%
            // 답변 버튼: re_YN이 Y이고, 관리자이고, 원글(p_id가 null)이고, 아직 답변 없을 때
            var showAnswer = (re_YN === 'Y' && cls === 'MNG' && !data.p_id && !hasAnswer);
        %>
        <% if (showAnswer) { %>
            <a href="/board/answer/<%= data.board_id %>/<%= boardtype.type_id %>">
                <button type="button" class="btn btn-warning me-md-2">답변</button>
            </a>
        <% } %>

        <a href="/board/view/<%= boardtype.numPerPage %>/<%= boardtype.type_id %>">
            <button type="button" class="btn btn-info me-md-2">목록</button>
        </a>

        <% if (cls === 'MNG' || loginid === data.loginid) { %>
            <a href="/board/update/<%= data.board_id %>/<%= boardtype.type_id %>">
                <button type="button" class="btn btn-info me-md-2">수정</button>
            </a>
            <a href="/board/delete/<%= data.board_id %>/<%= boardtype.type_id %>" onclick="if(confirm('정말로 삭제하시겠습니까?')==false) return false">
                <button type="button" class="btn btn-info me-md-2">삭제</button>
            </a>
        <% } %>
    </div>

<% } else if (mode === 'update') { %>
    <!-- ==================== 글 수정 모드 ==================== -->
    <h2><%= boardtype.title %> 수정</h2>
    <form action="/board/update_process" method="post">
        <input type="hidden" name="board_id" value="<%= data.board_id %>">
        <input type="hidden" name="type_id" value="<%= data.type_id %>">
        <input type="hidden" name="loginid" value="<%= data.loginid %>">
        <div class="mb-3">
            <label class="form-label">제목</label>
            <input class="form-control" type="text" name="title" style="width:300px;" value="<%= data.title %>">
        </div>
        <div class="mb-3">
            <label class="form-label">작성자</label>
            <input class="form-control" type="text" value="<%= data.writer_name || data.loginid %>" style="width:300px;" disabled>
        </div>
        <div class="mb-3">
            <label class="form-label">내용</label>
            <textarea class="form-control" name="content" style="width:800px; height:200px;"><%= data.content %></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">갱신삭제시 비밀번호</label>
            <input class="form-control" type="text" name="password" style="width:300px;">
        </div>
        <button class="btn btn-outline-primary btn-sm" type="submit">수정</button>
        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <a href="/board/view/<%= boardtype.numPerPage %>/<%= boardtype.type_id %>">
                <button type="button" class="btn btn-info me-md-2">목록</button>
            </a>
        </div>
    </form>

<% } %>

</div>
