<div class="container mt-4">
    <% if (mode === 'create') { %>
        <h2>게시판 생성</h2>
        <form action="/boardtype/create_process" method="post">
    <% } else { %>
        <h2>게시판 수정</h2>
        <form action="/boardtype/update_process" method="post">
            <input type="hidden" name="type_id" value="<%= data.type_id %>">
    <% } %>

        <div class="mb-3">
            <label class="form-label">제목</label>
            <input class="form-control" type="text" name="title" style="width:300px;" value="<%= data.title %>">
        </div>
        <div class="mb-3">
            <label class="form-label">설명</label>
            <input class="form-control" type="text" name="description" style="width:300px;" value="<%= data.description %>">
        </div>
        <div class="mb-3">
            <label class="form-label">페이지당 보여지는 글 수</label>
            <input class="form-control" type="text" name="numPerPage" style="width:300px;" value="<%= data.numPerPage %>">
        </div>

        <label class="form-label">일반 사용자 쓰기 가능 여부</label>
        <div class="mb-3">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="write_YN" id="write_YN1" value="Y" <%= data.write_YN === 'Y' ? 'checked' : '' %>>
                <label class="form-check-label" for="write_YN1">Yes</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="write_YN" id="write_YN2" value="N" <%= data.write_YN !== 'Y' ? 'checked' : '' %>>
                <label class="form-check-label" for="write_YN2">No</label>
            </div>
        </div>

        <label class="form-label">댓글 가능 여부</label>
        <div class="mb-3">
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="re_YN" id="re_YN1" value="Y" <%= data.re_YN === 'Y' ? 'checked' : '' %>>
                <label class="form-check-label" for="re_YN1">Yes</label>
            </div>
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="re_YN" id="re_YN2" value="N" <%= data.re_YN !== 'Y' ? 'checked' : '' %>>
                <label class="form-check-label" for="re_YN2">No</label>
            </div>
        </div>

        <button class="btn btn-outline-primary btn-sm" type="submit"><%= mode === 'create' ? '생성' : '수정' %></button>
        <a href="/boardtype/view" class="btn btn-outline-secondary btn-sm">목록 돌아가기</a>
    </form>
</div>
